<UserControl x:Class="ZipEase.UI.Core.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:core="clr-namespace:ZipEase.UI.Core"
             Focusable="True"
             KeyDown="OnKeyDown"
             MouseWheel="OnMouseWheel"
             Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Main Image Display Area ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                ClipToBounds="True"
                MouseLeftButtonDown="OnImageAreaMouseDown"
                MouseLeftButtonUp="OnImageAreaMouseUp"
                MouseMove="OnImageAreaMouseMove">
            <Image x:Name="PreviewImage"
                   Source="{Binding CurrentImage}"
                   Stretch="None"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}"
                                        ScaleY="{Binding ZoomLevel}"/>
                        <TranslateTransform X="{Binding PanOffsetX}"
                                            Y="{Binding PanOffsetY}"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Border>

        <!-- ── Loading Overlay ── -->
        <Grid Grid.Row="0"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <ui:ProgressRing IsIndeterminate="True"
                             Width="48" Height="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Error Overlay ── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
              Visibility="{Binding IsError, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="ErrorCircle24"
                               FontSize="36"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="400"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- ── Close Button (top-right corner) ── -->
        <ui:Button Grid.Row="0"
                   Icon="Dismiss24"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,8,8,0"
                   Command="{Binding CloseCommand}"
                   ToolTip="關閉預覽"/>

        <!-- ── Navigation Buttons (left/right edges) ── -->
        <ui:Button Grid.Row="0"
                   Icon="ChevronLeft24"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   Command="{Binding PreviousCommand}"
                   IsEnabled="{Binding CanGoPrevious}"
                   ToolTip="上一張"/>

        <ui:Button Grid.Row="0"
                   Icon="ChevronRight24"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"
                   Command="{Binding NextCommand}"
                   IsEnabled="{Binding CanGoNext}"
                   ToolTip="下一張"/>

        <!-- ── Zoom Controls Bar (bottom) ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ui:Button Icon="ZoomOut24"
                           Command="{Binding ZoomOutCommand}"
                           ToolTip="縮小"
                           Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ZoomPercentage, StringFormat='{}{0}%'}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           MinWidth="40"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="4,0"/>
                <ui:Button Icon="ZoomIn24"
                           Command="{Binding ZoomInCommand}"
                           ToolTip="放大"
                           Margin="4,0,4,0"/>
                <ui:Button Icon="ZoomFit24"
                           Command="{Binding FitToWindowCommand}"
                           ToolTip="適合視窗"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<Window x:Class="ZipEase.UI.Core.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ZipEase.UI.Core"
        Title="{Binding Source={x:Static core:L.Current}, Path=PasswordDialog_Title}"
        Width="360" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="{Binding Source={x:Static core:L.Current}, Path=PasswordDialog_Prompt}"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>
        <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding Source={x:Static core:L.Current}, Path=PasswordDialog_Confirm}"
                    IsDefault="True" MinWidth="80" Margin="0,0,8,0" Click="OnConfirm"/>
            <Button Content="{Binding Source={x:Static core:L.Current}, Path=PasswordDialog_Cancel}"
                    IsCancel="True" MinWidth="80" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
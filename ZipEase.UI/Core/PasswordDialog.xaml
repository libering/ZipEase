<Window x:Class="ZipEase.UI.Core.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="需要密碼"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="此壓縮檔受密碼保護，請輸入密碼："
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>
        <TextBlock x:Name="ErrorText"
                   Foreground="Red"
                   FontSize="12"
                   Margin="0,0,0,8"
                   Visibility="Collapsed"/>
        <PasswordBox x:Name="PasswordBox"
                     Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="確認"
                    IsDefault="True"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Click="OnConfirm"/>
            <Button Content="取消"
                    IsCancel="True"
                    MinWidth="80"
                    Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>

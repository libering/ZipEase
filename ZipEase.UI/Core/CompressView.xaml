<UserControl x:Class="ZipEase.UI.Core.CompressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:core="clr-namespace:ZipEase.UI.Core"
             AllowDrop="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Top Toolbar: Add Folder / Add Files / Reset ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:Button Content="{Binding Source={x:Static core:L.Current}, Path=Compress_AddFolder}"
                       Icon="FolderAdd24"
                       Command="{Binding AddFolderCommand}"
                       IsEnabled="{Binding IsCompressing, Converter={StaticResource InverseBool}}"
                       Margin="0,0,8,0"/>
            <ui:Button Content="{Binding Source={x:Static core:L.Current}, Path=Compress_AddFiles}"
                       Icon="Add24"
                       Command="{Binding AddFilesCommand}"
                       IsEnabled="{Binding IsCompressing, Converter={StaticResource InverseBool}}"
                       Margin="0,0,8,0"/>
            <ui:Button Icon="Dismiss24"
                       Content="{Binding Source={x:Static core:L.Current}, Path=Compress_Reset}"
                       Command="{Binding ResetCommand}"/>
        </StackPanel>

        <!-- ── File List / Drop Zone ── -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <!-- Empty state: drop hint -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsFileListEmpty, Converter={StaticResource BoolToVisibility}}">
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="36"
                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="將資料夾或檔案放在這裡"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- File list -->
                <ListBox ItemsSource="{Binding SelectedFiles}" BorderThickness="0"
                         Background="Transparent" FontSize="13" MinHeight="120"
                         Visibility="{Binding IsFileListEmpty, Converter={StaticResource InverseBoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- ── Start Button (shows options panel on click) ── -->
        <ui:Button Grid.Row="2"
                   Content="{Binding Source={x:Static core:L.Current}, Path=Compress_Start}"
                   Icon="Archive24" Appearance="Primary"
                   Command="{Binding ShowOptionsCommand}"
                   HorizontalAlignment="Left" Margin="0,0,0,12"
                   Visibility="{Binding IsOptionsVisible, Converter={StaticResource InverseBoolToVisibility}}"/>

        <!-- ── Options Panel (hidden until "開始壓縮" is clicked) ── -->
        <StackPanel Grid.Row="3" Visibility="{Binding IsOptionsVisible, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
            <!-- Output Path + Format -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0"
                            Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{Binding Source={x:Static core:L.Current}, Path=Compress_OutputPlaceholder}"
                            IsReadOnly="True" Margin="0,0,8,0"/>
                <ui:Button Grid.Column="1"
                           Content="{Binding Source={x:Static core:L.Current}, Path=Compress_Browse}"
                           Icon="Folder24"
                           Command="{Binding BrowseOutputCommand}"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Column="2" SelectedValue="{Binding SelectedFormat}" Width="100" Margin="0,0,8,0">
                    <ComboBoxItem Content="zip" IsSelected="True"/>
                    <ComboBoxItem Content="7z"/>
                    <ComboBoxItem Content="tar.gz"/>
                </ComboBox>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static core:L.Current}, Path=Compress_Level}"
                               VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                    <Slider Value="{Binding Level}" Minimum="0" Maximum="9" Width="80"
                            TickFrequency="1" IsSnapToTickEnabled="True"/>
                    <TextBlock Text="{Binding Level}" VerticalAlignment="Center"
                               Margin="6,0,0,0" FontSize="12" Width="14"/>
                </StackPanel>
            </Grid>
            <!-- Password -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                        Visibility="{Binding IsPasswordSupported, Converter={StaticResource BoolToVisibility}}">
                <CheckBox Content="{Binding Source={x:Static core:L.Current}, Path=Compress_Password}"
                          IsChecked="{Binding UsePassword, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ui:PasswordBox PlaceholderText="{Binding Source={x:Static core:L.Current}, Path=Compress_PasswordPlaceholder}"
                                Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="200" IsEnabled="{Binding UsePassword}"
                                Visibility="{Binding UsePassword, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
            <!-- Confirm compress button -->
            <ui:Button Content="{Binding Source={x:Static core:L.Current}, Path=Compress_Confirm}"
                       Icon="Checkmark24" Appearance="Primary"
                       Command="{Binding CompressCommand}"
                       HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- ── Progress ── -->
        <StackPanel Grid.Row="4" Margin="0,0,0,0">
            <StackPanel Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                <TextBlock Text="{Binding CurrentFile, StringFormat='壓縮中：{0}'}" FontSize="12" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ProgressBar Value="{Binding CompressProgress}" Height="6" Minimum="0" Maximum="100"/>
            </StackPanel>
            <ui:InfoBar IsOpen="{Binding IsStatusVisible, Mode=TwoWay}"
                        Severity="{Binding StatusSeverity}" Message="{Binding StatusMessage}" IsClosable="True"/>
        </StackPanel>
    </Grid>
</UserControl>

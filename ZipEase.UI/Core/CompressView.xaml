<UserControl x:Class="ZipEase.UI.Core.CompressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:core="clr-namespace:ZipEase.UI.Core">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: Add Files + Reset -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0"
                       Content="新增檔案"
                       Icon="Add24"
                       Command="{Binding AddFilesCommand}"
                       IsEnabled="{Binding IsCompressing, Converter={StaticResource InverseBool}}"/>
            <ui:Button Grid.Column="2"
                       Content="重設"
                       Icon="Dismiss24"
                       Command="{Binding ResetCommand}"/>
        </Grid>

        <!-- File List -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,0,12">
            <ListBox ItemsSource="{Binding SelectedFiles}"
                     BorderThickness="0"
                     Background="Transparent"
                     FontSize="13"
                     MinHeight="120"/>
        </Border>

        <!-- Output Row -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                        Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="輸出路徑..."
                        IsReadOnly="True"
                        Margin="0,0,8,0"/>

            <ui:Button Grid.Column="1"
                       Content="瀏覽"
                       Icon="Folder24"
                       Command="{Binding BrowseOutputCommand}"
                       IsEnabled="{Binding IsCompressing, Converter={StaticResource InverseBool}}"
                       Margin="0,0,8,0"/>

            <ComboBox Grid.Column="2"
                      SelectedValue="{Binding SelectedFormat}"
                      IsEnabled="{Binding IsCompressing, Converter={StaticResource InverseBool}}"
                      Width="100"
                      Margin="0,0,8,0">
                <ComboBoxItem Content="zip" IsSelected="True"/>
                <ComboBoxItem Content="7z"/>
                <ComboBoxItem Content="tar.gz"/>
            </ComboBox>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="等級" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                <Slider Value="{Binding Level}"
                        Minimum="0" Maximum="9"
                        Width="80"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        IsEnabled="{Binding IsCompressing, Converter={StaticResource InverseBool}}"/>
                <TextBlock Text="{Binding Level}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="12" Width="14"/>
            </StackPanel>
        </Grid>

        <!-- Compress Button -->
        <ui:Button Grid.Row="3"
                   Content="開始壓縮"
                   Icon="Archive24"
                   Appearance="Primary"
                   Command="{Binding CompressCommand}"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,12"/>

        <!-- Progress -->
        <StackPanel Grid.Row="4"
                    Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,12">
            <TextBlock Text="{Binding CurrentFile, StringFormat='壓縮中：{0}'}"
                       FontSize="12"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ProgressBar Value="{Binding CompressProgress}"
                         Height="6"
                         Minimum="0"
                         Maximum="100"/>
        </StackPanel>

        <!-- Status InfoBar -->
        <ui:InfoBar Grid.Row="5"
                    IsOpen="{Binding IsStatusVisible, Mode=TwoWay}"
                    Message="{Binding StatusMessage}"
                    IsClosable="True"/>
    </Grid>
</UserControl>

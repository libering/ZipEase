<Application x:Class="ZipEase.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:core="clr-namespace:ZipEase.UI.Core"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <core:InverseBoolConverter x:Key="InverseBool"/>
            <core:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <!-- Light-mode card background override: provides visual separation from window background.
                 This brush is managed by App.xaml.cs — added for Light theme, removed for Dark theme. -->
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#F5F5F5" />
            <!-- Global localisation source — bind with {Binding Source={x:Static core:L.Current}, Path=Nav_Extract} -->
        </ResourceDictionary>
    </Application.Resources>
</Application>

<ui:FluentWindow x:Class="ZipEase.UI.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:core="clr-namespace:ZipEase.UI.Core"
                 Title="ZipEase" Height="600" Width="900"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen">

    <Grid AllowDrop="True"
          DragEnter="OnDragEnter"
          DragOver="OnDragOver"
          DragLeave="OnDragLeave"
          Drop="OnDrop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar with window controls -->
        <ui:TitleBar Grid.Row="0"
                     Title="ZipEase"
                     ShowMinimize="True"
                     ShowMaximize="False"
                     ShowClose="True"/>

        <!-- Idle State: Drop Zone -->
        <Border Grid.Row="1"
                Visibility="{Binding IsIdleVisible, Converter={StaticResource BoolToVisibility}}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="12"
                Margin="40"
                Cursor="Hand"
                MouseLeftButtonDown="OnDropZoneClick">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDragOverActive}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Archive24" FontSize="72"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="將壓縮檔拖放到此處，或點擊瀏覽"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0"/>
                <TextBlock Text="支援 .zip, .rar, .7z, .tar, .gz 格式"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Preview State: Archive Contents -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibility}}"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Grid Grid.Row="0" Margin="0,8,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button — visible only when inside a subfolder -->
                <ui:Button Grid.Column="0"
                           Icon="ArrowLeft24"
                           Command="{Binding NavigateBackCommand}"
                           Visibility="{Binding IsBackButtonVisible, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,0,8,0"
                           ToolTip="上一頁"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding LoadedArchivePath}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <!-- File count -->
                <TextBlock Grid.Column="2"
                           Text="{Binding FileCount, StringFormat='{}{0} 個檔案'}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="12,0,12,0"/>

                <ui:Button Grid.Column="3"
                           Content="Extract All"
                           Icon="FolderArrowUp24"
                           Command="{Binding ExtractCommand}"
                           IsEnabled="{Binding IsExtractButtonEnabled}"
                           Appearance="Primary"
                           Margin="0,0,8,0"/>

                <ui:Button Grid.Column="4"
                           Content="Close"
                           Icon="Dismiss24"
                           Command="{Binding ResetCommand}"/>
            </Grid>

            <!-- Archive Contents DataGrid -->
            <DataGrid Grid.Row="1"
                      x:Name="ArchiveDataGrid"
                      ItemsSource="{Binding ArchiveEntries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      FontSize="13"
                      RowHeight="32"
                      BorderThickness="0"
                      MouseDoubleClick="OnDataGridDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File Name"
                                        Binding="{Binding FileName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding FileType}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Size"
                                        Binding="{Binding FormattedSize}"
                                        Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Progress Section -->
            <StackPanel Grid.Row="2"
                        Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,16,0,0">
                <TextBlock Text="{Binding CurrentExtractionFile, StringFormat='Extracting: {0}'}"
                           FontSize="12"
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ProgressBar Value="{Binding ExtractionProgress}"
                             Height="6"
                             Minimum="0"
                             Maximum="100"/>
            </StackPanel>

            <!-- Status InfoBar -->
            <ui:InfoBar Grid.Row="3"
                        IsOpen="{Binding IsStatusVisible, Mode=TwoWay}"
                        Message="{Binding StatusMessage}"
                        IsClosable="True"
                        Margin="0,12,0,0"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
